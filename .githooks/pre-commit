#!/usr/bin/env bash

set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

files=()
while IFS= read -r -d '' file; do
  files+=("$file")
done < <("$repo_root/tool/format_dart.sh" --staged --print0)

if [[ ${#files[@]} -eq 0 ]]; then
  exit 0
fi

"$repo_root/tool/format_dart.sh" --staged
git add -- "${files[@]}"
